{
	"name": "recoverage",
	"version": "0.1.16",
	"license": "BSD-3-Clause",
	"author": {
		"name": "Jeremy Banka",
		"email": "hello@jeremybanka.com"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeremybanka/recoverage.git",
		"directory": "packages/recoverage"
	},
	"type": "module",
	"files": [
		"bin",
		"dist",
		"src"
	],
	"main": "dist/recoverage.js",
	"types": "dist/recoverage.d.ts",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./src/recoverage.d.ts",
			"import": "./dist/recoverage.js"
		},
		"./lib": {
			"types": "./src/recoverage.lib.d.ts",
			"import": "./dist/recoverage.lib.js"
		}
	},
	"bin": {
		"recoverage": "bin/recoverage.bin.js"
	},
	"scripts": {
		"dev": "bun --bun tsdown --watch",
		"build": "bun --bun tsdown && rm -f dist/*.x.d.ts",
		"lint:biome": "biome check -- .",
		"lint:eslint": "eslint -- .",
		"lint:types": "tsgo --noEmit",
		"watch:types": "tsgo --watch --noEmit",
		"lint": "concurrently \"bun:lint:*\"",
		"test": "vitest",
		"test:once": "vitest run",
		"postversion": "biome format --write package.json"
	},
	"dependencies": {
		"@t3-oss/env-core": "0.13.11",
		"arktype": "2.2.1",
		"comline": "0.5.0",
		"diff": "9.0.0",
		"istanbul-lib-coverage": "3.2.2",
		"istanbul-lib-report": "3.0.1",
		"istanbul-reports": "3.2.0",
		"simple-git": "3.36.0",
		"takua": "0.2.1"
	},
	"devDependencies": {
		"@types/bun": "npm:bun-types@1.3.14",
		"@types/istanbul-lib-coverage": "2.0.6",
		"@types/istanbul-lib-report": "3.0.3",
		"@types/istanbul-reports": "3.0.4",
		"@types/node": "26.0.1",
		"@typescript/native-preview": "7.0.0-dev.20260630.1",
		"concurrently": "10.0.3",
		"eslint": "10.6.0",
		"nyc": "18.0.0",
		"recoverage-fixtures": "workspace:*",
		"tsdown": "0.22.3",
		"typescript": "6.0.3",
		"vite": "8.1.0",
		"vitest": "4.1.9",
		"yalc": "1.0.0-pre.53"
	}
}
