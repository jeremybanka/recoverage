{
	"name": "recoverage-monorepo",
	"version": "1.0.0",
	"type": "module",
	"description": "",
	"main": "index.js",
	"workspaces": [
		"packages/*",
		"recoverage.cloud"
	],
	"scripts": {
		"gen": "turbo run gen",
		"lint": "turbo run lint",
		"lint:biome": "turbo run lint:biome",
		"lint:deps": "pin-checker --ignore-workspaces",
		"lint:eslint": "turbo run lint:eslint",
		"lint:types": "turbo run lint:types",
		"watch:types": "turbo run watch:types --concurrency=30",
		"lint:fix:biome": "biome check --write *",
		"lint:fix:eslint": "NODE_OPTIONS=--require=./scripts/eslint-typescript.cjs eslint --fix .",
		"fmt": "biome format .",
		"fmt:fix": "biome format --write .",
		"build": "turbo run build",
		"bench": "cd lib && vitest bench",
		"test": "cross-env CI=true turbo run test:once --concurrency=2",
		"test:coverage:increased": "cross-env CI=true turbo run test:coverage:increased",
		"test:semver": "cross-env CI=true turbo run test:semver",
		"release": "bun run build && changeset publish",
		"notes": "changeset",
		"nuke": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' + && rm bun.lock",
		"update-workflows": "bun ./scripts/update-workflows.bun.ts"
	},
	"keywords": [],
	"author": "",
	"license": "BSD-3-Clause",
	"devDependencies": {
		"@biomejs/biome": "2.5.5",
		"@changesets/cli": "2.31.1",
		"@eslint/eslintrc": "3.3.6",
		"@eslint/js": "10.0.1",
		"@types/eslint": "9.6.1",
		"@typescript-eslint/eslint-plugin": "8.65.0",
		"@typescript-eslint/parser": "8.65.0",
		"c8": "12.0.0",
		"cross-env": "10.1.0",
		"eslint": "10.7.0",
		"eslint-plugin-import-x": "4.17.1",
		"eslint-plugin-simple-import-sort": "14.0.0",
		"jiti": "2.7.0",
		"pin-dependencies-checker": "2.7.1",
		"turbo": "2.10.6",
		"typescript": "7.0.2",
		"typescript-eslint-typescript": "npm:typescript@6.0.3",
		"typescript-language-server": "5.3.0",
		"vscode-langservers-extracted": "4.10.0"
	},
	"packageManager": "bun@1.3.10",
	"trustedDependencies": [
		"@biomejs/biome",
		"bun",
		"esbuild",
		"rolldown",
		"sharp",
		"unrs-resolver",
		"workerd"
	],
	"overrides": {
		"rolldown-plugin-dts": "0.27.13"
	}
}
